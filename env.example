# Lazarus Protocol — Environment Variables
# Copy this to .env and fill in your values. NEVER commit .env to git.

# Alert: Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
ALERT_FROM_EMAIL=lazarus@yourdomain.com
ALERT_TO_EMAIL=your_personal_email@gmail.com

# Alert: Telegram (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# IPFS (optional — falls back to local if not set)
IPFS_API_URL=http://127.0.0.1:5001
PINATA_API_KEY=your_pinata_key
PINATA_SECRET_KEY=your_pinata_secret

# Vault config
VAULT_PATH=~/.lazarus/vault.json
CHECKIN_INTERVAL_DAYS=30
