# === Lazarus Protocol .gitignore ===

# NEVER commit these — secrets and keys
.env
*.pem
*.key
*.p12
vault.json
encrypted_secrets.bin
key_blob
secrets_decrypted.*
decryption_kit.zip

# Lazarus runtime data
~/.lazarus/
.lazarus/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
*.whl

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing & coverage
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
*.xml

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Local artifacts
security_review.txt

# Jupyter (if ever used for docs/demos)
.ipynb_checkpoints/
