# Docker ignore file for Lazarus Protocol

# Git
.git
.gitignore
.gitattributes
.gitmodules

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.ruff_cache
.mypy_cache
.coverage

# Virtual environments
venv/
.venv/
env/

# Build artifacts
dist/
build/
*.egg-info/
*.egg

# Development files
.vscode/
.idea/
*.swp
*.swo
*~

# Documentation
docs/_build/

# Test files
test_*
*.test

# Logs
*.log
logs/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# System files
.DS_Store
Thumbs.db

# Large files
*.tar.gz
*.zip

# OS-specific
*.service
*.sh

# Configuration files that should be mounted
config.yaml
secrets.yaml

# Exclude unnecessary large directories
assets/  # Keep this if needed, but exclude if large
web/static/  # Keep if needed

# Exclude development tools
node_modules/
bower_components/

# Exclude backup files
*.bak
*.backup

# Exclude IDE files
*.iml
*.ipr
*.iws

# Exclude macOS files
.DS_Store
.AppleDouble
.LSOverride

# Exclude Windows files
Desktop.ini

# Exclude Linux files
*~

# Exclude Docker files
Dockerfile
.dockerignore

# Exclude CI/CD files
.github/
.gitlab-ci.yml
.travis.yml

# Exclude packaging files (but allow Dockerfile to copy them)
# Note: These are excluded from build context but explicitly copied in Dockerfile
MANIFEST.in
setup.cfg